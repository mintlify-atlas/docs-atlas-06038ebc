  "keyFeatures": [
    "YAML-based CV definition with JSON Schema validation",
    "Multiple built-in themes (Classic, Moderncv, Sb2nov, Engineeringresumes, Engineeringclassic)",
    "Extensive design customization (colors, typography, margins, spacing)",
    "Multi-format output (PDF via Typst, Markdown, HTML, PNG)",
    "Live preview with --watch mode for auto-reloading",
    "Internationalization support with customizable locales",
    "Custom theme creation and template overriding",
    "Strict validation with helpful error messages"
  ],
  "publicApiSurface": [
    "rendercv new - Generate sample CV YAML file",
    "rendercv render - Convert YAML to PDF/Markdown/HTML/PNG",
    "rendercv create-theme - Create custom theme templates",
    "rendercv --version - Show installed version",
    "EducationEntry - Education background entry type",
    "ExperienceEntry - Work experience entry type",
    "PublicationEntry - Publication entry type",
    "NormalEntry - Generic entry with title and details",
    "OneLineEntry - Compact single-line entry",
    "BulletEntry - Simple bullet point entry"
  ]
